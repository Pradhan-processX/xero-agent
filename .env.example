# ============================================================
#  Xero Timesheet Agent — environment
#  Copy to .env and fill in. NEVER commit .env.
# ============================================================

# --- Xero OAuth2 app (developer.xero.com) ---
# Scopes the app must request: projects projects.read offline_access openid profile email
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
XERO_REDIRECT_URI=http://localhost:3000/auth/callback
# The org (tenant) the connection is for. Filled automatically after first auth (see token store),
# but you can pin it here if the connection has access to multiple orgs.
XERO_TENANT_ID=

# Where refresh/access tokens are persisted (Phase 1: local JSON file).
XERO_TOKEN_FILE=./.tokens.json

# Mock mode: set true to run with seeded projects/tasks (NO real Xero connection needed).
# Writes are logged to .mock-xero-time.json instead of posted. Set false once connected.
XERO_MOCK=false

# --- LLM for narration grounding ---
# Uses OpenAI-compatible API. For Azure OpenAI set AZURE_OPENAI_* instead.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Azure OpenAI (used automatically when AZURE_OPENAI_ENDPOINT is set; leave OPENAI_API_KEY as-is)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_TRIAGE_DEPLOYMENT=gpt-4.1-mini
# AZURE_OPENAI_API_VERSION=2024-06-01

# --- Agent behaviour ---
# Below this the entry is flagged for confirmation rather than auto-accepted.
NLU_CONFIDENCE_THRESHOLD=0.70
# Used by the Friday review to flag under/over-logged weeks.
DEFAULT_WEEKLY_HOURS=37.5
# Per-person map + draft store (local JSON files when no Azure storage configured).
USER_MAP_FILE=./config/userMap.json
DRAFT_STORE_FILE=./.drafts.json
# Alternative to the file: paste the whole userMap JSON here (handy as an App Service setting).
# USER_MAP_JSON={"users":[...]}

# --- Persistence backend ---
# Leave AZURE_STORAGE_CONNECTION_STRING blank for local JSON files (single machine).
# Set it (Azure Storage account) to use shared Azure Table Storage for tokens + drafts
# — REQUIRED once the backend is deployed and used by multiple teammates.
AZURE_STORAGE_CONNECTION_STRING=
# AZURE_TOKEN_TABLE=xerotokens
# AZURE_DRAFT_TABLE=drafts
# AZURE_CONVERSATION_TABLE=conversations

# --- Server ---
PORT=3000
# Shared secret Copilot Studio / the connector must send in the `x-api-key` header.
API_KEY=change-this-to-a-long-random-string

# --- Observability ---
# Leave blank for local dev (console-only logging). Set in Azure App Service application settings
# to enable Application Insights. Find the connection string in: Azure Portal → Application Insights
# resource → Overview → Connection String.
APPLICATIONINSIGHTS_CONNECTION_STRING=
